{
  "inputs": [
    {
      "type": "promptString",
      "id": "googleCalendarClientId",
      "description": "Google Calendar MCP OAuth client ID",
      "password": false
    }
  ],
  "servers": {
    "googleCalendar": {
      "type": "http",
